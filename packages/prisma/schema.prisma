// Health Saviors — AI Healthcare Agent Platform
// Clean schema for Web4.0 MVP

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User (wallet-based auth — no username, no password) ──
model User {
  id            String   @id @default(uuid()) @db.Uuid
  walletAddress String   @unique @map("wallet_address") @db.VarChar(42) // 0x... ETH address
  nonce         String   @default(uuid()) @db.VarChar(100) // for signature verification
  displayName   String?  @map("display_name") @db.VarChar(50) // user-set nickname shown in app & used by AI
  profileComplete Boolean @default(false) @map("profile_complete")
  age           Int?     @db.SmallInt
  heightCm      Float?   @map("height_cm") @db.Real
  weightKg      Float?   @map("weight_kg") @db.Real
  tokenBalance  Int      @default(20000) @map("token_balance")
  dataConsent   Boolean  @default(false) @map("data_consent")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  chronicConditions UserChronicCondition[]
  userAgents        UserAgent[]
  conversations     Conversation[]
  healthRecords     HealthRecord[]
  tokenTransactions TokenTransaction[]
  consentLogs       ConsentLog[]
  auditLogs         AuditLog[]
  waterLogs         WaterLog[]
  mealLogs          MealLog[]
  exerciseLogs      ExerciseLog[]
  sleepLogs         SleepLog[]
  moodLogs          MoodLog[]
  meditationLogs    MeditationLog[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityLikes    CommunityLike[]
  pushSubscriptions PushSubscription[]
  notificationPrefs NotificationPrefs?
  notifications     Notification[]

  @@map("users")
}

// In-app notification log — every push we send is also written here so the
// user can scroll back through them in the bell dropdown, even when the OS
// push couldn't be delivered (offline, push disabled, etc.).
model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  category  String?  @db.VarChar(30) // rewards / reminders / agentFollowups / community / system
  title     String   @db.VarChar(200)
  body      String?  @db.Text
  url       String?  @db.Text
  icon      String?  @db.VarChar(200)
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, read])
  @@map("notifications")
}

// ── Web Push Notifications ──
model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique @db.Text // Push service URL (FCM/APNs/Mozilla)
  p256dh    String   @db.VarChar(200) // Public key for ECDH
  auth      String   @db.VarChar(50)  // Auth secret
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  lastUsed  DateTime @default(now()) @map("last_used") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPrefs {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  rewards         Boolean  @default(true)  // streak/milestone rewards
  reminders       Boolean  @default(true)  // daily check-in nudges
  agentFollowups  Boolean  @default(true)  // AI agent proactive messages
  community       Boolean  @default(false) // likes/comments on your posts
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_prefs")
}

// ── Personal AI Agents (each user owns 4 individual agents) ──
model UserAgent {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  agentType       String   @map("agent_type") @db.VarChar(20) // nurse, gatekeeper, nutritionist, mindcare
  nickname        String   @db.VarChar(50) // user-customizable agent name
  personality     String?  @db.Text // custom personality notes
  memoryContext   Json?    @map("memory_context") @db.JsonB // persistent agent memory (preferences, recurring topics)
  telegramChatId  String?  @map("telegram_chat_id") @db.VarChar(50)
  telegramEnabled Boolean  @default(false) @map("telegram_enabled")
  isActive        Boolean  @default(true) @map("is_active")
  lastInteraction DateTime? @map("last_interaction") @db.Timestamptz
  totalMessages   Int      @default(0) @map("total_messages")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentType])
  @@index([userId])
  @@index([telegramChatId])
  @@map("user_agents")
}

// ── Chronic Conditions Survey (mandatory on signup) ──
model UserChronicCondition {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  conditionCode String @map("condition_code") @db.VarChar(20) // Internal code
  conditionName String @map("condition_name") @db.VarChar(100)
  severity    String?  @db.VarChar(20) // mild, moderate, severe
  sinceYear   Int?     @map("since_year") @db.SmallInt
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conditionCode])
  @@index([userId])
  @@map("user_chronic_conditions")
}

// ── Conversations ──
model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  agentType String   @map("agent_type") @db.VarChar(20) // nurse, gatekeeper, nutritionist, mindcare
  summary   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, agentType])
  @@index([userId, updatedAt])
  @@map("conversations")
}

// ── Messages ──
model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String   @db.VarChar(10) // user, assistant, system
  content        String   @db.Text
  agentType      String   @map("agent_type") @db.VarChar(20)
  metadata       Json?    @db.JsonB // triageLevel, department, riskScore, tags
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ── Health Records (HL7 FHIR R4 format, encrypted) ──
model HealthRecord {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  resourceType   String   @map("resource_type") @db.VarChar(50) // Observation, Condition, Encounter, etc.
  fhirResource   Json     @map("fhir_resource") @db.JsonB // HL7 FHIR R4 JSON resource
  encryptedRaw   String?  @map("encrypted_raw") @db.Text // AES-256 encrypted original data
  sourceAgent    String?  @map("source_agent") @db.VarChar(20) // which agent generated this
  sourceConversationId String? @map("source_conversation_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resourceType])
  @@index([userId, createdAt])
  @@map("health_records")
}

// ── Token Transactions ──
enum TokenTransactionType {
  SIGNUP_BONUS
  AGENT_SUBSCRIPTION
  HEALTH_CHECKIN
  DATA_REWARD
  REFERRAL
  DAILY_LOG
  DAILY_MISSION
  WEEKLY_MISSION
  CHALLENGE_REWARD
  MEDITATION_REWARD
  AI_CHAT_SPEND
  AI_REPORT_SPEND
}

model TokenTransaction {
  id          String               @id @default(uuid()) @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  amount      Int                  // positive = earn, negative = spend
  type        TokenTransactionType
  description String?              @db.VarChar(200)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
  @@map("token_transactions")
}

// ── Consent Log (GDPR / PIPA compliance) ──
model ConsentLog {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  consentType String    @map("consent_type") @db.VarChar(50) // health_data_collection, data_processing, ai_analysis
  granted     Boolean
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  userAgent   String?   @map("user_agent") @db.VarChar(500)
  grantedAt   DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consentType])
  @@map("consent_logs")
}

// ── Audit Log (data access tracking) ──
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(50) // data_access, data_export, data_delete, login, logout
  resource  String?  @db.VarChar(100) // what was accessed
  details   Json?    @db.JsonB
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ════════════════════════════════════════════════════════
// Module A — Daily Health Log
// ════════════════════════════════════════════════════════

// ── Water Log ──
model WaterLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  amountMl  Int      @default(250) @map("amount_ml") // default 1 cup = 250ml
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("water_logs")
}

// ── Meal Log ──
model MealLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  mealType    String   @map("meal_type") @db.VarChar(20) // breakfast, lunch, dinner, snack
  description String   @db.Text // what they ate
  calories    Int?     // AI-estimated calories
  protein     Float?   @db.Real // grams
  carbs       Float?   @db.Real
  fat         Float?   @db.Real
  photoUrl    String?  @map("photo_url") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("meal_logs")
}

// ── Exercise Log ──
model ExerciseLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  exerciseType String   @map("exercise_type") @db.VarChar(50) // walking, running, cycling, gym, yoga, etc.
  durationMin  Int      @map("duration_min") // minutes
  distanceKm   Float?   @map("distance_km") @db.Real
  calories     Int?     // estimated calories burned
  intensity    String?  @db.VarChar(10) // light, moderate, vigorous
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("exercise_logs")
}

// ── Sleep Log ──
model SleepLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  bedtime   DateTime @db.Timestamptz // when they went to bed
  wakeTime  DateTime @map("wake_time") @db.Timestamptz // when they woke up
  quality   Int?     @db.SmallInt // 1-5 rating
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("sleep_logs")
}

// ── Mood Log ──
model MoodLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  score     Int      @db.SmallInt // 1-5
  note      String?  @db.VarChar(500) // optional note
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("mood_logs")
}

// ════════════════════════════════════════════════════════
// Module E — Mindfulness / Meditation
// ════════════════════════════════════════════════════════

model MeditationLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  durationMin Int      @map("duration_min")
  sessionType String   @map("session_type") @db.VarChar(30) // breathing, body_scan, guided, free
  note        String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("meditation_logs")
}

// ════════════════════════════════════════════════════════
// Module H — Community
// ════════════════════════════════════════════════════════

model CommunityPost {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  category  String   @db.VarChar(30) // general, challenge, diary, tips
  title     String?  @db.VarChar(200) // optional — Instagram-style posts may have no title
  content   String   @db.Text
  imageUrl  String?  @map("image_url") @db.Text // legacy single image
  images    Json?    @db.JsonB // ordered array of base64 data URIs (multi-photo carousel)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments CommunityComment[]
  likes    CommunityLike[]

  @@index([userId])
  @@index([category, createdAt])
  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([userId])
  @@map("community_comments")
}

model CommunityLike {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@map("community_likes")
}
